# MeshPilot Environment Configuration
# Copy to .env and fill in your values before running docker compose up

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-32-char-string

# Admin account (created on first startup)
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD=change-me-in-production

# ── Inference ─────────────────────────────────────────────────────────────────
# CPU threads for llama.cpp (set to physical core count)
LLAMA_THREADS=4

# Context window size (tokens)
LLAMA_CTX_SIZE=4096

# Batch size for continuous batching
LLAMA_BATCH_SIZE=512

# Max inference time before timeout (seconds)
INFERENCE_TIMEOUT_S=120

# ── Quantization ──────────────────────────────────────────────────────────────
# Default quantization bits for uploaded models (4 or 8)
AUTO_QUANT_BITS=4

# ── Services ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
DATABASE_URL=sqlite+aiosqlite:///./data/meshpilot.db

# Internal service URLs (used by FastAPI to reach inference servers)
LLAMACPP_URL=http://llamacpp:8080
ONNX_URL=http://onnx:8090

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Requests per minute per API key (0 = unlimited)
RATE_LIMIT_RPM=60

# ── Storage ───────────────────────────────────────────────────────────────────
# Local path inside container for model files
MODEL_STORAGE_PATH=/data/models

# ── Monitoring ────────────────────────────────────────────────────────────────
# Grafana admin password
GRAFANA_ADMIN_PASSWORD=admin

# ── Optional: HTTPS ───────────────────────────────────────────────────────────
# Set to your domain for automatic Let's Encrypt SSL (requires port 443 open)
# DOMAIN=meshpilot.yourcompany.com
